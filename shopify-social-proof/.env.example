# Shopify App credentials - get these from your Partner Dashboard
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here

# Your app's deployed URL
SHOPIFY_APP_URL=https://your-app-domain.com

# OAuth scopes
SCOPES=read_orders,read_products,read_customers,write_script_tags,read_script_tags

# Database
DATABASE_URL="file:./dev.db"

# Optional: Custom shop domain for testing
# SHOP_CUSTOM_DOMAIN=your-store.myshopify.com
